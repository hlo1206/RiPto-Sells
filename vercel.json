{
  "buildCommand": "pnpm --filter @workspace/ripto-sells run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": null,
  "build": {
    "env": {
      "BASE_PATH": "/"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
